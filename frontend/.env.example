# ── 백엔드 API 설정 ────────────────────────────────────────────────────
# 개발 환경: Next.js 프록시를 통해 CORS 없이 호출 (기본값 빈 문자열)
# 프로덕션: 실제 API 서버 URL 입력
NEXT_PUBLIC_API_URL=

# 서버사이드 리라이트 대상 (next.config.js에서 사용)
API_URL=http://localhost:8000

# ── 인증 ──────────────────────────────────────────────────────────────
# API 서버에 API_KEYS 설정 시 동일한 키를 여기에 입력
# 미입력 시 데모 모드로 실행 (인증 없음)
NEXT_PUBLIC_API_KEY=
