# Shoealls Gait Analysis API — 환경변수 예시
# 복사 후 .env로 이름 변경하여 사용

# ── API 인증 ───────────────────────────────────────────────────────
# 쉼표로 여러 키 지정. 미설정 시 인증 비활성화 (데모/개발 모드)
API_KEYS=your-api-key-here,another-key

# ── 로깅 ──────────────────────────────────────────────────────────
# 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# 형식: text (컬러 텍스트) | json (구조적 JSON)
LOG_FORMAT=text

# ── 서버 ──────────────────────────────────────────────────────────
WORKERS=2

# ── 모델 (선택) ────────────────────────────────────────────────────
# 사전학습 체크포인트 경로 (없으면 데모 모드)
# CHECKPOINT_PATH=outputs/best_model.pt
